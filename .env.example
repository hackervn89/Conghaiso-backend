# ========================================
# CẤU HÌNH MÔI TRƯỜNG - CÔNG HẢI SỐ API
# ========================================
# Sao chép file này thành .env và điền các giá trị thật vào.
# KHÔNG BAO GIỜ COMMIT FILE .env LÊN GIT!
# ========================================

# --- Cấu hình PostgreSQL ---
DB_USER=your_db_user
DB_HOST=localhost
DB_NAME=conghaiso_db
DB_PASSWORD=your_db_password
DB_PORT=5433

# --- Cấu hình Server ---
PORT=3000

# --- JWT Secret (Tạo chuỗi ngẫu nhiên dài, ví dụ: openssl rand -base64 64) ---
JWT_SECRET=your_jwt_secret_here

# --- Google AI & FCM ---
GOOGLE_FCM_CREDENTIALS_PATH=src/config/fcm_credentials.json
GEMINI_API_KEY=your_gemini_api_key

# --- Model AI (khuyến nghị theo quota Free tier) ---
CHAT_MODEL=gemini-3.1-flash-lite-preview
RAG_MODEL=gemini-3.1-flash-lite-preview
SUMMARY_MODEL=gemini-3.1-flash-lite-preview
EMBEDDING_MODEL=gemini-embedding-001
# Khuyến nghị đặt <= 2000 để tạo vector index ANN (hnsw/ivfflat) ổn định hơn.
# Ví dụ: 1536 hoặc 1024. Để trống/0 nếu muốn dùng dimension mặc định của model.
EMBEDDING_OUTPUT_DIMENSIONS=1536
# Số chunk RAG lấy cho câu hỏi thông thường / câu hỏi tổng hợp
RAG_TOP_K=12
RAG_SUMMARY_TOP_K=30
SUMMARY_MAX_TOKENS_PER_CHUNK=120000

# --- Import metadata tài liệu hành chính ---
ADMIN_DOCS_EXCEL_PATH=/absolute/path/to/Dac_ta_du_lieu_2025_2030.xlsx
ADMIN_DOCS_DATA_ROOT=/absolute/path/to/1. LƯU VB DO ĐẢNG UỶ BAN HÀNH NHIỆM KỲ 2025-2030
# Rate limit riêng cho action ghi của module /api/admin-documents (tính theo user đã đăng nhập)
ADMIN_DOCS_WRITE_RATE_LIMIT_MAX=120

# --- Cấu hình Connection Pool ---
DB_POOL_MAX=100
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=20000

# --- Cấu hình Redis ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
# Đặt 'true' để tắt Redis caching (dùng khi dev không có Redis)
# DISABLE_REDIS_CACHE=true

# --- Lưu trữ File ---
STORAGE_PATH=/path/to/your/uploads/

# --- Cache TTL (giây) ---
CACHE_TTL_MEETING_DETAILS=900
